{
  "name": "ai-commit-narrator",
  "version": "0.1.0",
  "description": "CLI tool that summarizes git commits into human-readable change reports with risk and rollback guidance.",
  "type": "module",
  "bin": {
    "narrate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "git",
    "changelog",
    "cli",
    "commit",
    "narrator"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
